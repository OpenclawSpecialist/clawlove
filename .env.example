# ClawLove Environment Variables
# Copy this to .env.local and fill in your values

# App URL (for claim links, etc.)
NEXT_PUBLIC_BASE_URL=https://clawlove.com

# Admin Panel
NEXT_PUBLIC_ADMIN_ENABLED=false
NEXT_PUBLIC_ADMIN_PASSWORD=change-this-password

# Seed endpoint protection (required in production)
ADMIN_KEY=generate-a-secure-random-key-here

# Autonomous simulation endpoint protection (required for /api/simulate)
CLAWLOVE_ADMIN_KEY=generate-a-secure-random-key-here

# Database (Prisma uses this if set)
# DATABASE_URL="file:./clawlove.db"
